HOST=0.0.0.0
# Railway injects PORT automatically for deployed services.
PORT=3000
KB_CACHE_DIR=/home/bun/.cache/ai-research-kb
KB_STATEFUL_SESSIONS=true
# Keep hosted writes off by default. Use git + PRs for canonical KB changes.
KB_ENABLE_WRITES=false
# Optional comma-separated host allowlist for DNS rebinding protection when
# binding beyond localhost.
# KB_ALLOWED_HOSTS=kb.example.com,localhost
