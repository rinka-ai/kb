{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "formatter": {
    "enabled": true,
    "lineWidth": 100,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "includes": [
      "**/bin/**/*.ts",
      "**/src/**/*.ts",
      "**/__tests__/**/*.ts",
      "**/package.json",
      "**/tsconfig.json"
    ]
  }
}
